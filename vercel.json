{
  "version": 2,
  "builds": [
    { "src": "/client/src/index.js", "use": "@vercel/node" },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "framework": null,
  "rewrites":  [
    {"source": "/(.*)", "destination": "/client/src/index.js"}
  ]
  
}