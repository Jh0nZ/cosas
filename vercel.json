{
  "version": 2,
  "builds": [
    {
      "src": "server/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "client/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "back/(.*)",
      "dest": "server/wsgi.py"
    },
    {
      "src": "front/(.*)",
      "dest": "client/src/index.js"
    }
  ]
}
